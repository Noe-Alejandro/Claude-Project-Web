# Copy this file to .env.development or .env.production
# Never commit real secrets — this file is for documentation only

VITE_APP_NAME="Enterprise App"
VITE_APP_VERSION="1.0.0"

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL="http://localhost:5000/api"

# Request timeout in milliseconds
VITE_API_TIMEOUT=10000

# Set to true to use mocked API responses (dev/test only)
VITE_USE_MOCK_API=false

# Log level: debug | info | warn | error
VITE_LOG_LEVEL="info"

# Enable TanStack Query Devtools
VITE_ENABLE_DEVTOOLS=true

# Sentry DSN for error monitoring (production)
# VITE_SENTRY_DSN=""
